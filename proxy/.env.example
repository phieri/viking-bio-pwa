# Port for the HTTP/HTTPS dashboard server (default: 3000, valid range: 1-65535)
HTTP_PORT=3000

# Port for framed TCP telemetry ingest from provisioned Pico bridges (default: 9000)
INGEST_TCP_PORT=9000

# Set to 1/true to require TLS on the ingest listener.
# Requires TLS_CERT_PATH and TLS_KEY_PATH.
# INGEST_TCP_TLS=0

# Webhook removed — reprovision devices to use INGEST_TCP_PORT=9000 and
# per-device telemetry keys.

# ---------------------------------------------------------------------------
# Automatic HTTPS via DuckDNS + Let's Encrypt (recommended for production)
# ---------------------------------------------------------------------------
# DDNS_SUBDOMAIN=my-viking-bio    # subdomain part of <subdomain>.duckdns.org
# DDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Let's Encrypt contact e-mail (recommended; used for expiry notices)
# ACME_EMAIL=admin@example.com

# Set ACME_STAGING=1 to use the Let's Encrypt staging environment for testing
# ACME_STAGING=1

# Directory where ACME certificate cache is stored (default: DATA_DIR)
# ACME_CERT_DIR=/etc/viking-bio-proxy/certs

# Port for the HTTP-01 ACME challenge server (default: 80)
# ACME_HTTP_PORT=80

# ---------------------------------------------------------------------------
# Manual HTTPS with a user-supplied certificate (alternative to DDNS above)
# ---------------------------------------------------------------------------
# TLS_CERT_PATH=/etc/ssl/certs/server.crt
# TLS_KEY_PATH=/etc/ssl/private/server.key

# ---------------------------------------------------------------------------
# Web Push / VAPID
# ---------------------------------------------------------------------------
# Contact email included in VAPID JWT sent with each push notification.
# VAPID_CONTACT_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# mDNS / DNS-SD
# ---------------------------------------------------------------------------
# MDNS_NAME=Viking Bio
# MDNS_DISABLE=1

# ---------------------------------------------------------------------------
# Device configurator (viking-bio-proxy --configure)
# ---------------------------------------------------------------------------
# USB serial port for the --configure subcommand. When set, the configurator
# uses this port automatically without prompting.
# Linux:   PICO_SERIAL_PORT=/dev/ttyACM0
# macOS:   PICO_SERIAL_PORT=/dev/cu.usbmodem101
# Windows: PICO_SERIAL_PORT=COM3
# PICO_SERIAL_PORT=

# ---------------------------------------------------------------------------
# Data directory
# ---------------------------------------------------------------------------
# Directory for VAPID keys (server-vapid.pub, server-vapid.priv) and
# subscriptions (subscriptions.json). Default: ~/.viking-bio-bridge on Linux,
# otherwise <exe_dir>/data
# DATA_DIR=/var/lib/viking-bio-proxy

# ---------------------------------------------------------------------------
# Energy comparison card
# ---------------------------------------------------------------------------
# Show a dashboard card with the current price difference (SEK/kWh) between
# electrical heating and the pellet burner. A positive value means the burner
# saves money; a negative value (shown in red) means electricity is cheaper.
# Set ENERGY_CARD_ENABLED=1 to enable the card.
# ENERGY_CARD_ENABLED=1

# Spot price region for elprisetjustnu.se (SE1, SE2, SE3, SE4). Default: SE3
# ELEC_PRICE_REGION=SE3

# Electricity grid fee per kWh (öre/kWh as decimal SEK, e.g. 0.40 for 40 öre)
# ELEC_GRID_FEE_SEK_KWH=0.40

# Electricity energy tax per kWh (e.g. 0.533 for Swedish energy tax)
# ELEC_TAX_SEK_KWH=0.533

# Annual fixed electricity subscription fee in SEK (e.g. nätabonnemang)
# ELEC_FIXED_COST_SEK_YEAR=2400

# Direct pellet energy cost per kWh of heat (SEK/kWh)
# BURNER_COST_SEK_KWH=0.30

# Annual fixed burner costs in SEK (service, insurance, amortization, etc.)
# BURNER_FIXED_COST_SEK_YEAR=3000

# Estimated annual heating energy in kWh, used to amortize fixed costs.
# Default: 20000
# ANNUAL_HEATING_KWH=20000
