# Port for the HTTP/HTTPS dashboard server (default: 3000)
HTTP_PORT=3000

# Webhook authentication token – the Pico bridge must send this value in the
# X-Hook-Auth request header. Set to a strong random string in production.
# Leave empty to disable authentication (development only).
MACHINE_WEBHOOK_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Automatic HTTPS via DuckDNS + Let's Encrypt (recommended for production)
# ---------------------------------------------------------------------------
# DuckDNS (https://www.duckdns.org/) is a free, open-source Dynamic DNS
# service.  Setting DDNS_SUBDOMAIN and DDNS_TOKEN enables automatic HTTPS:
#   1. The server registers its public IP with DuckDNS every 5 minutes.
#   2. A Let's Encrypt TLS certificate is obtained for <subdomain>.duckdns.org
#      using the ACME HTTP-01 challenge.
#   3. The certificate is renewed automatically 30 days before expiry.
#   4. The HTTPS server reloads the renewed certificate without restart.
#
# Requirements:
#   - Port 80 must be reachable from the internet for the HTTP-01 challenge.
#     On Linux: sudo setcap cap_net_bind_service+ep $(which node)
#               or: iptables -t nat -A PREROUTING -p tcp --dport 80 -j REDIRECT --to-port <ACME_HTTP_PORT>
#   - The main dashboard port (HTTP_PORT) should be 443 for standard HTTPS.
#
# DDNS_SUBDOMAIN=my-viking-bio    # subdomain part of <subdomain>.duckdns.org
# DDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # from duckdns.org/install

# Let's Encrypt contact e-mail (strongly recommended; used for expiry notices)
# ACME_EMAIL=admin@example.com

# Set ACME_STAGING=1 to use the Let's Encrypt staging environment for testing
# (issues non-trusted certificates but has much higher rate limits).
# ACME_STAGING=1

# Directory where certificates and the ACME account key are stored.
# Default: proxy/data/  (server.crt, server.key, acme-account.key)
# ACME_CERT_DIR=/etc/viking-bio/certs

# Port for the HTTP-01 ACME challenge server (default: 80).
# Change this if the process cannot bind port 80 directly and you are using
# a port-forwarding rule (e.g. iptables → 8080) or a reverse proxy.
# ACME_HTTP_PORT=80

# ---------------------------------------------------------------------------
# Manual HTTPS with a user-supplied certificate (alternative to DDNS above)
# ---------------------------------------------------------------------------
# When both paths are set the server starts with HTTPS; otherwise plain HTTP.
# For a self-signed certificate (development):
#   openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:P-256 \
#     -keyout server.key -out server.crt -days 365 -nodes -subj '/CN=localhost'
# TLS_CERT_PATH=/etc/ssl/certs/server.crt
# TLS_KEY_PATH=/etc/ssl/private/server.key

# Pico W base URL for forwarding push subscriptions to the device so it can
# send Web Push notifications directly.  Use a bracketed IPv6 literal when the
# Pico W is reachable only over IPv6 (e.g. http://[fe80::dead:beef%25eth0]:8080).
# Leave empty to keep push notifications on the proxy side.
# PICO_BASE_URL=http://[::1]:8080

# VAPID public key from the Pico W (output of STATUS command over USB serial
# after first boot, e.g. "vapid_pub: <base64url>").  When set, browsers
# subscribe using the Pico's key so that push notifications can be sent
# directly from the device.  Leave empty to use the proxy's own VAPID key.
# PICO_VAPID_PUBLIC_KEY=

# Contact e-mail included in the VAPID JWT sent with each Web Push notification.
# Used by push services to reach the site operator in case of abuse or delivery
# issues.  Falls back to "mailto:admin@viking-bio.local" when unset.
# VAPID_CONTACT_EMAIL=admin@example.com

# Zero-conf proxy discovery via mDNS/DNS-SD (_viking-bio._tcp).
# The proxy advertises itself as a DNS-SD service so it can be found by
# standard mDNS clients: Bonjour (macOS), Avahi (Linux), Windows mDNS.
# Browse with:  node proxy/scripts/dns-sd-browser.js
#   macOS:      dns-sd -B _viking-bio._tcp local
#   Linux:      avahi-browse _viking-bio._tcp --resolve
# Note: web browsers/PWAs cannot speak mDNS directly; discovery must be
# performed by a local Node.js agent or native OS tool.
#
# MDNS_NAME=Viking Bio  # DNS-SD service instance name (default: "Viking Bio")
# MDNS_DISABLE=1        # Set to 1 to suppress advertisement (e.g. in Docker/CI)
